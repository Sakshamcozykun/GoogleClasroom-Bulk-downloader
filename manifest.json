{
  "manifest_version": 2,
  "name": "Classroom Bulk Downloader",
  "version": "2.2.0",
  "description": "Bulk download Google Classroom file attachments with ease.",

  "permissions": [
    "downloads",
    "activeTab",
    "tabs",
    "storage",
    "https://classroom.google.com/*",
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://drive.usercontent.google.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["https://classroom.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_title": "Classroom Bulk Downloader"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
